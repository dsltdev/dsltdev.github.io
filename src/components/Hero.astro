---
---

<section id="home" class="hero">
  <div class="hero-bg">
    <div class="gradient-mesh"></div>
    <div class="particles" id="particles"></div>
    <div class="grid-overlay"></div>
  </div>
  
  <div class="hero-content">
    <div class="hero-text">
      <p class="hero-greeting animate-on-scroll">
        <span class="greeting-line"></span>
        Hola, soy
      </p>
      <h1 class="hero-name animate-on-scroll">
        <span class="name-highlight">David</span>
        <span class="name-gradient">López</span>
      </h1>
      <h2 class="hero-title animate-on-scroll">
        <span class="title-word">Full Stack</span>
        <span class="title-divider">/</span>
        <span class="title-word accent typing-text" id="typingText">Creative Developer</span>
        <span class="cursor-blink">|</span>
      </h2>
      <p class="hero-description animate-on-scroll">
        Creo experiencias digitales que fusionan <span class="highlight">diseño innovador</span> 
        con <span class="highlight">tecnología de vanguardia</span>. 
        Transformo ideas en realidad digital.
      </p>
      
      <div class="hero-cta animate-on-scroll">
        <a href="#projects" class="btn-primary">
          <span>Ver Proyectos</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#contact" class="btn-secondary">
          <span>Contactar</span>
        </a>
      </div>

      <div class="hero-stats animate-on-scroll">
        <div class="stat">
          <span class="stat-number" data-count="5">0</span>
          <span class="stat-plus">+</span>
          <span class="stat-label">Años de Experiencia</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number" data-count="50">0</span>
          <span class="stat-plus">+</span>
          <span class="stat-label">Proyectos Completados</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number" data-count="30">0</span>
          <span class="stat-plus">+</span>
          <span class="stat-label">Clientes Satisfechos</span>
        </div>
      </div>
    </div>

    <div class="hero-visual animate-on-scroll">
      <div class="code-window">
        <div class="window-header">
          <div class="window-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="window-title">developer.ts</span>
        </div>
        <div class="window-content">
          <pre><code><span class="code-keyword">const</span> <span class="code-variable">developer</span> = {'{'}
  <span class="code-property">name</span>: <span class="code-string">"David López"</span>,
  <span class="code-property">role</span>: <span class="code-string">"Full Stack Dev"</span>,
  <span class="code-property">passion</span>: <span class="code-string">"Creating impact"</span>,
  <span class="code-method">build</span>: () ={">"} {'{'}
    <span class="code-keyword">return</span> <span class="code-string">"Amazing things"</span>;
  {'}'}
{'}'};

<span class="code-keyword">export default</span> developer;</code></pre>
        </div>
      </div>
    </div>
  </div>

  <div class="scroll-indicator">
    <div class="mouse">
      <div class="wheel"></div>
    </div>
    <span>Scroll Down</span>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding-top: 120px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .gradient-mesh {
    position: absolute;
    inset: 0;
    background: var(--gradient-mesh);
    opacity: 0.6;
    animation: gradient-shift 20s ease infinite;
    background-size: 200% 200%;
  }

  .particles {
    position: absolute;
    inset: 0;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(139, 92, 246, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(139, 92, 246, 0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 60%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 60%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 5%;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 6rem;
    align-items: center;
    width: 100%;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .hero-greeting {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--accent-primary);
    animation: slide-in-left 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    letter-spacing: 0.05em;
  }

  .greeting-line {
    width: 50px;
    height: 2px;
    background: var(--gradient-button);
    border-radius: var(--radius-full);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 700;
    line-height: 1.05;
    animation: slide-up 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.2s forwards;
    opacity: 0;
    letter-spacing: -0.03em;
  }

  .name-highlight {
    display: block;
    color: var(--text-primary);
  }

  .name-gradient {
    background: var(--gradient-text);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 4s ease infinite;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 1rem;
    animation: slide-up 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
    opacity: 0;
  }

  .title-divider {
    color: var(--accent-primary);
    font-weight: 300;
    opacity: 0.5;
  }

  .title-word.accent {
    color: var(--accent-primary);
    font-weight: 500;
  }

  .cursor-blink {
    color: var(--accent-primary);
    animation: blink 1s step-end infinite;
    font-weight: 300;
    text-shadow: 0 0 10px var(--accent-glow);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-description {
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.9;
    max-width: 550px;
    animation: slide-up 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.6s forwards;
    opacity: 0;
    letter-spacing: 0.01em;
  }

  .highlight {
    color: var(--text-primary);
    font-weight: 600;
    background: var(--gradient-text);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-cta {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.5rem;
    animation: slide-up 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.8s forwards;
    opacity: 0;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.1rem 2.25rem;
    background: var(--gradient-button);
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: white;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(139, 92, 246, 0.3);
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.25) 0%, transparent 50%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .btn-primary:hover::before {
    opacity: 1;
  }

  .btn-primary:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 8px 40px rgba(139, 92, 246, 0.5), 0 0 60px rgba(139, 92, 246, 0.2);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 1.1rem 2.25rem;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
    transition: all var(--transition-base);
    background: var(--bg-card);
    backdrop-filter: blur(10px);
  }

  .btn-secondary:hover {
    border-color: var(--accent-primary);
    background: rgba(139, 92, 246, 0.1);
    transform: translateY(-4px);
    box-shadow: 0 4px 30px rgba(139, 92, 246, 0.2);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 3rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-subtle);
    animation: slide-up 0.8s cubic-bezier(0.4, 0, 0.2, 1) 1s forwards;
    opacity: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-mono);
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
    background: var(--gradient-text);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-plus {
    font-size: 1.75rem;
    color: var(--accent-primary);
    font-weight: 300;
    margin-left: 2px;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: center;
    font-family: var(--font-display);
    letter-spacing: 0.02em;
  }

  .stat-divider {
    width: 1px;
    height: 45px;
    background: linear-gradient(180deg, transparent, var(--border-default), transparent);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    animation: scale-in 1s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
    opacity: 0;
  }

  .code-window {
    width: 100%;
    max-width: 520px;
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
    overflow: hidden;
    box-shadow: 
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      0 0 80px rgba(139, 92, 246, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    animation: float 8s ease-in-out infinite;
    position: relative;
  }

  .code-window::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    padding: 1px;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.3), transparent 50%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .window-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(18, 18, 30, 0.8);
    border-bottom: 1px solid var(--border-subtle);
  }

  .window-dots {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    transition: all var(--transition-fast);
  }

  .dot:hover {
    transform: scale(1.2);
  }

  .dot.red { 
    background: #ff5f56;
    box-shadow: 0 0 8px rgba(255, 95, 86, 0.5);
  }
  .dot.yellow { 
    background: #ffbd2e;
    box-shadow: 0 0 8px rgba(255, 189, 46, 0.5);
  }
  .dot.green { 
    background: #27c93f;
    box-shadow: 0 0 8px rgba(39, 201, 63, 0.5);
  }

  .window-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .window-content {
    padding: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.8;
    overflow-x: auto;
    background: linear-gradient(180deg, var(--bg-secondary) 0%, rgba(10, 10, 18, 0.95) 100%);
  }

  .window-content pre {
    margin: 0;
  }

  .code-keyword { 
    color: var(--accent-secondary);
    font-weight: 500;
  }
  .code-variable { 
    color: var(--neon-cyan);
  }
  .code-property { 
    color: var(--text-primary);
  }
  .code-string { 
    color: var(--neon-green);
  }
  .code-method { 
    color: var(--accent-primary);
    font-weight: 500;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    animation: bounce 2s infinite;
  }

  .mouse {
    width: 26px;
    height: 40px;
    border: 2px solid var(--text-muted);
    border-radius: 15px;
    position: relative;
  }

  .wheel {
    width: 4px;
    height: 8px;
    background: var(--accent-1);
    border-radius: 2px;
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    animation: scroll-wheel 1.5s infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
  }

  @keyframes scroll-wheel {
    0% { opacity: 1; top: 8px; }
    100% { opacity: 0; top: 20px; }
  }

  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-text {
      align-items: center;
    }

    .hero-greeting {
      justify-content: center;
    }

    .hero-description {
      text-align: center;
    }

    .hero-cta {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }

    .code-window {
      max-width: 400px;
    }
  }

  @media (max-width: 640px) {
    .hero-stats {
      flex-direction: column;
      gap: 1.5rem;
    }

    .stat-divider {
      width: 40px;
      height: 1px;
    }

    .hero-cta {
      flex-direction: column;
      width: 100%;
    }

    .btn-primary, .btn-secondary {
      justify-content: center;
      width: 100%;
    }
  }
</style>

<script>
  // Particle animation
  const particlesContainer = document.getElementById('particles');
  if (particlesContainer) {
    for (let i = 0; i < 50; i++) {
      const particle = document.createElement('div');
      particle.style.cssText = `
        position: absolute;
        width: ${Math.random() * 4 + 1}px;
        height: ${Math.random() * 4 + 1}px;
        background: rgba(99, 102, 241, ${Math.random() * 0.5 + 0.1});
        border-radius: 50%;
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 100}%;
        animation: float ${Math.random() * 10 + 10}s linear infinite;
        animation-delay: ${Math.random() * 10}s;
      `;
      particlesContainer.appendChild(particle);
    }
  }

  // Counter animation
  const counters = document.querySelectorAll('.stat-number');
  const observerOptions = { threshold: 0.5 };

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const counter = entry.target as HTMLElement;
        const target = parseInt(counter.getAttribute('data-count') || '0');
        let current = 0;
        const increment = target / 50;
        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            counter.textContent = target.toString();
            clearInterval(timer);
          } else {
            counter.textContent = Math.floor(current).toString();
          }
        }, 40);
        counterObserver.unobserve(counter);
      }
    });
  }, observerOptions);

  counters.forEach(counter => counterObserver.observe(counter));

  // Typing animation
  const typingElement = document.getElementById('typingText');
  if (typingElement) {
    const texts = ['Creative Developer', 'UI/UX Designer', 'Problem Solver', 'Tech Enthusiast'];
    let textIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    let isPaused = false;

    function type() {
      const currentText = texts[textIndex];
      
      if (isPaused) {
        setTimeout(type, 2000);
        isPaused = false;
        isDeleting = true;
        return;
      }

      if (isDeleting) {
        typingElement.textContent = currentText.substring(0, charIndex - 1);
        charIndex--;
      } else {
        typingElement.textContent = currentText.substring(0, charIndex + 1);
        charIndex++;
      }

      let typeSpeed = isDeleting ? 50 : 100;

      if (!isDeleting && charIndex === currentText.length) {
        typeSpeed = 2000;
        isPaused = true;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        textIndex = (textIndex + 1) % texts.length;
      }

      setTimeout(type, typeSpeed);
    }

    setTimeout(type, 1500);
  }

  // Magnetic buttons
  const magneticButtons = document.querySelectorAll('.btn-primary, .btn-secondary');
  
  magneticButtons.forEach((btn) => {
    btn.addEventListener('mousemove', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      const rect = (btn as HTMLElement).getBoundingClientRect();
      const x = mouseEvent.clientX - rect.left - rect.width / 2;
      const y = mouseEvent.clientY - rect.top - rect.height / 2;
      
      (btn as HTMLElement).style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
    });

    btn.addEventListener('mouseleave', () => {
      (btn as HTMLElement).style.transform = 'translate(0, 0)';
    });
  });
</script>
